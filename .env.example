# --- Architect LLM (offline blueprint generation) ---
ARCHITECT_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Responder LLM (runtime, per-attack) ---
RESPONDER_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b
RESPONDER_TIMEOUT_S=15

# --- Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-long-random-string

# --- Deception tuning ---
TARPIT_ENABLED=true
TARPIT_BASE_DELAY_MS=80
TARPIT_MAX_DELAY_MS=4000
FAKE_DB_ROWS_PER_TABLE=50

# --- SSH bridge to Cowrie ---
SSH_BRIDGE_ENABLED=true
